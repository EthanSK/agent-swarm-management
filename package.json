{
  "name": "agent-swarm-management",
  "version": "0.1.0",
  "private": true,
  "description": "Native macOS command center for tracking agent-driven projects, tasks, follow-ups, and proof.",
  "author": "EthanSK",
  "license": "MIT",
  "homepage": "https://github.com/EthanSK/agent-swarm-management",
  "repository": {
    "type": "git",
    "url": "https://github.com/EthanSK/agent-swarm-management.git"
  },
  "scripts": {
    "build": "swift build",
    "build:mac": "./scripts/build-mac-app.sh",
    "install:mac": "./scripts/install-mac-app.sh",
    "version:sync": "node ./scripts/sync-version.mjs",
    "version:check": "node ./scripts/check-version-consistency.mjs",
    "verify:mac": "./scripts/verify-mac-app.sh",
    "version:bump:check": "node ./scripts/check-version-bump.mjs",
    "version:bump:patch": "node ./scripts/bump-version.mjs && npm run version:sync",
    "version:bump:minor": "node ./scripts/bump-version.mjs minor && npm run version:sync",
    "release:desktop:mac": "npm run build:mac"
  }
}
